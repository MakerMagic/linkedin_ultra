{
  "manifest_version": 3,
  "name": "LinkedIn CRM Bootstrap",
  "description": "Открывает LinkedIn Connections при запуске браузера без дублей вкладок.",
  "version": "0.1.0",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabs"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*"
  ],
  "action": {
    "default_title": "LinkedIn CRM Bootstrap"
  }
}
