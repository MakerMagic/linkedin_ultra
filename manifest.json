{
  "manifest_version": 3,
  "name": "LinkedIn CRM Bootstrap",
  "description": "LinkedIn CRM — панель и фоновая подготовка Connections.",
  "version": "0.2.0",
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "notifications"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "action": {
    "default_title": "Открыть LinkedIn CRM"
  }
}
